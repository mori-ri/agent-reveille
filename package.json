{
  "name": "agent-reveille",
  "version": "0.1.12",
  "description": "AI agent task scheduler with launchd integration",
  "type": "module",
  "bin": {
    "reveille": "dist/bin/reveille.js"
  },
  "scripts": {
    "dev": "tsx bin/reveille.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "ai",
    "agent",
    "cron",
    "scheduler",
    "launchd",
    "claude",
    "cli",
    "tui"
  ],
  "author": "mori-ri",
  "license": "MIT",
  "homepage": "https://github.com/mori-ri/agent-reveille#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mori-ri/agent-reveille.git"
  },
  "bugs": {
    "url": "https://github.com/mori-ri/agent-reveille/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "^5.4.0",
    "cron-parser": "^5.0.0",
    "cronstrue": "^2.52.0",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.1.0",
    "react": "^18.3.0",
    "update-notifier": "^7.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "@types/update-notifier": "^6.0.8",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
